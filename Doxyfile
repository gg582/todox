# Doxyfile for todox

PROJECT_NAME           = todox
PROJECT_BRIEF          = "CLI alarm manager with optional desktop notification daemon"
PROJECT_NUMBER         = 1.0.0

OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES

INPUT                  = include src README.md
FILE_PATTERNS          = *.c *.h *.md
RECURSIVE              = YES
EXCLUDE                = src/compat/bsd/README.md
USE_MDFILE_AS_MAINPAGE = README.md

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_MAN           = NO

EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = NO

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

TAB_SIZE               = 4
OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = NO

DISABLE_INDEX          = NO
GENERATE_TREEVIEW      = YES
